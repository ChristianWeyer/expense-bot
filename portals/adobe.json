{
    "id": "adobe",
    "name": "Adobe",
    "homepage": "https://account.adobe.com",
    "billing_url": "https://account.adobe.com/orders",
    "auth_check_url": "https://account.adobe.com/orders",
    "auth_check_selector": "table, [data-testid*='order']",
    "match_keywords": ["ADOBE"],
    "invoices": {
        "selector": "a[href*='invoice'], a:has-text('Download'), button:has-text('Invoice')",
        "fields": {
            "pdf_url": {"selector": "self", "attribute": "href"}
        }
    },
    "download": {
        "method": "direct_link"
    }
}
