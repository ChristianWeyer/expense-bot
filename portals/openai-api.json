{
    "id": "openai-api",
    "name": "OpenAI API",
    "homepage": "https://platform.openai.com",
    "billing_url": "https://platform.openai.com/settings/organization/billing/history",
    "auth_check_url": "https://platform.openai.com/settings/organization/billing/history",
    "auth_check_selector": "a[href*='stripe.com'], h1:has-text('Billing')",
    "match_keywords": ["OPENAI"],
    "exclude_keywords": ["CHATGPT"],
    "invoices": {
        "selector": "tr:has(a[href*='stripe.com'])",
        "fields": {
            "amount": {"selector": "td:nth-child(3)"},
            "date": {"selector": "td:nth-child(4)"},
            "pdf_url": {"selector": "a[href*='stripe.com']", "attribute": "href"}
        }
    },
    "download": {
        "method": "stripe_url"
    }
}
