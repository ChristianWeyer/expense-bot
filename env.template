# ─── Email-Versand ────────────────────────────────────
RECIPIENT_EMAIL=kollegin@example.com
CC_EMAIL=

# ─── Microsoft Graph API (OAuth) ─────────────────────
AZURE_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
AZURE_TENANT_ID=common

# ─── OpenAI API (GPT Vision für MC-PDF Parsing) ─────
OPENAI_API_KEY=sk-...
LLM_MODEL=gpt-5.4

# ─── 1Password CLI ───────────────────────────────────
# Alle Vendor-Credentials werden automatisch aus 1Password gelesen.
# Format: op://<vault>/<item>/<field>
# Falls 1Password nicht verfügbar: Credentials direkt als
# VENDOR_EMAIL=... / VENDOR_PASSWORD=... setzen (überschreibt 1PW).

OP_BAHN_EMAIL=op://Private/Bahn/username
OP_BAHN_PASSWORD=op://Private/Bahn/password
OP_AMAZON_EMAIL=op://Private/Amazon - Thinktecture/email
OP_AMAZON_PASSWORD=op://Private/Amazon - Thinktecture/password
# SPIEGEL: op://Shared/Spiegel/username + password (hardcoded in spiegel.py)
# FIGMA:   op://Private/Figma/username + password (hardcoded in config.py)
# GOOGLE:  op://Private/Google - Christian/username + password
# HEISE:   op://Shared/heise.de/username + password
# ADOBE:   op://Shared/Adobe/username + password
# OPENAI:  op://Private/Open AI.com/username + password

# ─── Cloudflare API ──────────────────────────────────
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_GLOBAL_API_KEY=

# ─── Browser / CDP ───────────────────────────────────
CDP_URL=http://localhost:9222
MC_PDF=

# ─── Outlook Belegsuche ─────────────────────────────
BELEGE_FOLDER=Belege
BELEGE_SEARCH_FOLDERS=Belege,Archiv,Archive
BELEGE_DATE_TOLERANCE=35

# ─── Vendor-Konfiguration ───────────────────────────
FIGMA_TEAM_ID=
OWN_EMAIL_DOMAIN=thinktecture.com

# ─── Cleanup ────────────────────────────────────────
KEEP_DAYS=30

# ─── Testing ───────────────────────────────────────
# RUN_LLM_TESTS=1 aktiviert LLM-Tests (kostet ~$0.50 pro Lauf)
RUN_LLM_TESTS=0
