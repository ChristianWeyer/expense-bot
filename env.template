# ─── bahn.de Zugangsdaten ──────────────────────────────
BAHN_EMAIL=deine.email@example.com
BAHN_PASSWORD=dein-passwort

# ─── Empfänger ─────────────────────────────────────────
RECIPIENT_EMAIL=kollegin@example.com

# CC-Empfänger (optional, leer lassen wenn nicht benötigt)
CC_EMAIL=

# ─── Microsoft Graph API (OAuth) ──────────────────────
# Azure App Registration → App (Client) ID
# Anleitung: siehe README
AZURE_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Tenant ID (oder "common" für Multi-Tenant / persönliche Accounts)
AZURE_TENANT_ID=common

# ─── Standard-Optionen ────────────────────────────────
# CDP-URL zum Chrome (Canary) mit Debug-Port (leer = eigener Playwright-Browser)
CDP_URL=http://localhost:9222

# Pfad zum Mastercard-PDF (leer = "Meine Reisen"-Modus)
# Kann auch ein Ordnerpfad sein – dann wird das neueste PDF im Ordner genutzt
MC_PDF=

# Rechnungen älter als X Tage aus rechnungen/ löschen (Standard: 30)
KEEP_DAYS=30
